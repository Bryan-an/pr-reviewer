generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model ReviewRun {
  id            String   @id @default(cuid())
  prUrl         String
  org           String
  project       String
  repoId        String
  repoName      String
  prId          Int
  title         String
  sourceRefName String
  targetRefName String
  baseSha       String
  headSha       String
  engineName    String
  createdAt     DateTime @default(now())

  findings Finding[]

  @@index([prUrl, createdAt])
}

model Finding {
  id             String  @id @default(cuid())
  reviewRunId    String
  findingKey     String
  severity       String
  category       String
  title          String
  message        String
  filePath       String?
  lineStart      Int?
  lineEnd        Int?
  recommendation String?

  createdAt DateTime @default(now())

  reviewRun ReviewRun @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)

  @@unique([reviewRunId, findingKey])
}

model Repository {
  id        String   @id @default(cuid())
  org       String
  project   String
  adoRepoId String
  name      String
  remoteUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rules RepoRule[]

  @@unique([org, project, adoRepoId])
  @@index([org, project, name])
}

model RepoRule {
  id           String   @id @default(cuid())
  repositoryId String
  title        String
  markdown     String
  enabled      Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId, enabled, sortOrder, updatedAt])
}
